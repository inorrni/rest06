# Supabase 프로젝트 설정 (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 카카오 로그인은 Supabase Auth의 Kakao OAuth provider를 사용합니다.
# 1) Supabase 대시보드 → Authentication → Providers → Kakao 활성화
# 2) Kakao Developers(https://developers.kakao.com)에서 앱 생성 후
#    REST API 키 / Client Secret 을 Supabase Kakao provider에 입력
# 3) Kakao 앱의 Redirect URI 에 아래 값을 등록:
#    https://YOUR-PROJECT.supabase.co/auth/v1/callback
# 따로 프론트엔드 환경변수는 필요 없습니다.
